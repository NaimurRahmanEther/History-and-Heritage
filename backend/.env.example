DATABASE_URL=postgresql://postgres:postgres@localhost:5432/traditional_market
PORT=5000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change-this-to-a-long-random-secret
# Optional aliases (supported for compatibility):
# JWT_SECRET_KEY=change-this-to-a-long-random-secret
# SECRET_KEY=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
# Optional admin DB override for db:init (default: postgres)
# DB_ADMIN_NAME=postgres
# DB_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres
